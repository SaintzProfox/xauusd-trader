# =============================================================
# GOLDBOT — Environment Configuration
# Copy to .env and fill in your values
# NEVER commit .env to version control
# =============================================================

# ─── Database ─────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=tradingbot
DB_USER=postgres
DB_PASSWORD=your_strong_password_here
DATABASE_URL=postgresql://postgres:your_strong_password_here@localhost:5432/tradingbot

# ─── Redis ────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379

# ─── JWT Security ─────────────────────────────────────────────
JWT_SECRET=generate-with-openssl-rand-hex-64
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ─── Credentials Encryption ───────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
CREDENTIALS_ENCRYPTION_KEY=generate-a-32-char-hex-string-here

# ─── MetaTrader 5 / HFM ───────────────────────────────────────
MT5_LOGIN=12345678
MT5_PASSWORD=your_mt5_password
MT5_SERVER=HFMarkets-Demo        # or HFMarkets-Live01 for real
MT5_PATH=                        # Leave empty to auto-detect MT5 path

# ─── Bot Settings ─────────────────────────────────────────────
BOT_PROCESS_NAME=trading_bot

# ─── ML Model ─────────────────────────────────────────────────
ML_MODEL_PATH=ml/models/signal_classifier.pkl

# ─── Frontend ─────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://yourdomain.com

# ─── API ──────────────────────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:3000","https://yourdomain.com"]
ENVIRONMENT=production

# ─── Admin User (seeded on first run) ─────────────────────────
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_me_immediately
